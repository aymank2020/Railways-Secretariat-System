# =============================================================================
# Railway Secretariat System (Flutter) – production environment template
# =============================================================================
# Copy to `.env` and edit before running `docker compose -f docker-compose.prod.yml up -d`.
# Never commit a real .env to git — it is listed in .gitignore.
# =============================================================================

# --- Web frontend exposure -------------------------------------------------
# Port that nginx (the Flutter Web bundle) listens on, on the host.
WEB_BIND_PORT=80
# Bind to all interfaces so devices on the LAN can reach it. Set to
# 127.0.0.1 to make it loopback-only and force traffic via Cloudflare.
WEB_BIND_HOST=0.0.0.0

# --- Server (Dart API) -----------------------------------------------------
# 1 = log every request to stdout, 0 = quiet.
SECRETARIAT_LOG_REQUESTS=1
# Maximum login attempts per IP per 5-minute window.
SECRETARIAT_LOGIN_RATE_LIMIT=10
# Comma-separated list of allowed CORS origins. Leave empty to allow none
# (recommended when you only ever access the API through nginx on the
# same origin). Set e.g. to https://secretariat.example.com if you serve
# the Flutter clients from a different domain.
SECRETARIAT_CORS_ORIGINS=

# --- Cloudflare Tunnel (optional) ------------------------------------------
# Token issued by `cloudflared tunnel token <tunnel-name>` on a trusted
# admin machine. Uncomment to enable; then start the optional cloudflared
# service via:
#   docker compose -f docker-compose.prod.yml --profile tunnel up -d
# CLOUDFLARE_TUNNEL_TOKEN=

# --- Initial admin password (used by deploy/scripts/bootstrap.sh) ----------
# If left blank, the bootstrap script generates a random password and writes
# it to /opt/railways-secretariat-flutter/INITIAL_CREDENTIALS.txt (mode 0600).
# RAILWAYS_INITIAL_ADMIN_PASSWORD=
