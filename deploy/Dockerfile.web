# syntax=docker/dockerfile:1.6
#
# Compiles the Flutter Web bundle and serves it through a hardened nginx.
# nginx also reverse-proxies /api/* to the Dart server so the Flutter Web
# bundle can call its own origin and avoid CORS entirely.
FROM dart:3.5.4 AS dart-base
# (dart:3.5.4 ships dart but not flutter; we install Flutter on top.)

FROM debian:bookworm-slim AS builder

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates curl git unzip xz-utils zip libglu1-mesa \
 && rm -rf /var/lib/apt/lists/*

# Pin Flutter to a version compatible with the pubspec.
ENV FLUTTER_VERSION=3.41.9
ENV FLUTTER_HOME=/opt/flutter
ENV PATH=${FLUTTER_HOME}/bin:${PATH}
RUN git clone --depth 1 --branch ${FLUTTER_VERSION} \
        https://github.com/flutter/flutter.git ${FLUTTER_HOME} \
 && flutter config --no-analytics \
 && flutter doctor -v || true

WORKDIR /build

# Cache pub deps.
COPY pubspec.yaml pubspec.lock* ./
RUN flutter pub get || true

# Copy sources and build.
COPY . .
RUN flutter pub get
RUN flutter build web --release \
        --no-wasm-dry-run \
        --no-web-resources-cdn \
        --dart-define=API_BASE_URL=

# ---------------------------------------------------------------------------
FROM nginx:1.27-alpine AS runner

RUN apk add --no-cache curl

# Drop the default config so our hardened one is the only one served.
RUN rm -f /etc/nginx/conf.d/default.conf
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

# Static bundle.
COPY --from=builder /build/build/web /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=3s --start-period=5s --retries=3 \
  CMD curl --fail --silent --max-time 2 http://127.0.0.1/healthz > /dev/null || exit 1
