/android/app/profile
/android/app/release

# Database files
*.db
*.db-journal

# Temporary files
*.tmp
*.temp
tmp/

# Production build archives
production_*/
.production_dir.txt

# JVM crash logs
hs_err_pid*.log

# Flutter crash logs
flutter_*.log

# Misc data files (not source)
*.xlsx
*.pdf
*.jpeg
*.zip
nul

# Python helper scripts
*.pyc
__pycache__/

# Android build reports
android/build/

# Tesseract OCR data (large binary files)
tools/tessdata*/

# Production secrets / generated files
.env
INITIAL_CREDENTIALS.txt
secretariat_data/

# Flutter pubspec backup created by build_server.sh
pubspec.yaml.bak

# Local Dart-only compiled binary
/server_main
/build_artifacts/
